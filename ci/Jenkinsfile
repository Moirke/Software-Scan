// Jenkinsfile — Repository Scanner build pipeline
//
// Produces the Docker image artifact used for deployment.
//
// Stages:
//   1. Install Python deps
//   2. Run full test suite with coverage report
//   3. Build Docker image (tagged by build number + git SHA)
//   4. Smoke test — start the container and verify /health responds
//   5. Save image as repo-scanner-<N>.tar.gz and archive to Jenkins
//   6. Remove local image to keep the agent disk clean
//
// Outputs:
//   Jenkins artifact: repo-scanner-<BUILD_NUMBER>.tar.gz
//
// Next step after a successful build:
//   See runbooks/upgrade.md to deploy the artifact to the VM.

pipeline {
    agent any

    environment {
        IMAGE_NAME = 'repo-scanner'
        IMAGE_TAG  = "${env.BUILD_NUMBER}"
        TAR_FILE   = "repo-scanner-${env.BUILD_NUMBER}.tar.gz"
    }

    stages {

        stage('Install dependencies') {
            steps {
                sh 'pip install --quiet -r requirements.txt'
            }
        }

        stage('Lint') {
            steps {
                sh 'pylint src/'
            }
        }

        stage('Test') {
            steps {
                sh 'coverage run -m unittest discover tests/'
            }
            post {
                always {
                    sh 'coverage report'
                    sh 'coverage html'
                    publishHTML(target: [
                        allowMissing:          false,
                        alwaysLinkToLastBuild: true,
                        keepAll:               true,
                        reportDir:             'htmlcov',
                        reportFiles:           'index.html',
                        reportName:            'Coverage Report',
                    ])
                }
            }
        }

        stage('Build image') {
            steps {
                sh """
                    docker build \\
                        --tag  ${IMAGE_NAME}:${IMAGE_TAG} \\
                        --tag  ${IMAGE_NAME}:latest \\
                        --label org.opencontainers.image.revision=\$(git rev-parse --short HEAD) \\
                        --label org.opencontainers.image.created=\$(date -u +%Y-%m-%dT%H:%M:%SZ) \\
                        .
                """
            }
        }

        stage('Smoke test') {
            steps {
                script {
                    // Run the image on a high port and confirm the health endpoint responds.
                    // The container is stopped whether the test passes or fails.
                    def cid = sh(
                        script: "docker run -d --rm -p 18080:8080 ${IMAGE_NAME}:${IMAGE_TAG}",
                        returnStdout: true
                    ).trim()
                    try {
                        sh 'sleep 5 && curl --silent --fail http://localhost:18080/health'
                    } finally {
                        sh "docker stop ${cid} || true"
                    }
                }
            }
        }

        stage('Save artifact') {
            steps {
                // Typical image is ~200 MB; gzip compresses it to ~60 MB.
                sh "docker save ${IMAGE_NAME}:${IMAGE_TAG} | gzip > ${TAR_FILE}"
                archiveArtifacts artifacts: "${TAR_FILE}", fingerprint: true
            }
        }

        stage('Remove local image') {
            steps {
                sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest || true"
            }
        }
    }

    post {
        success {
            echo """
Build ${BUILD_NUMBER} succeeded.

Artifact : ${TAR_FILE}
Download : ${BUILD_URL}artifact/${TAR_FILE}

Deploy following runbooks/upgrade.md
"""
        }
        failure {
            echo 'Build failed — check the stage output above for details.'
        }
        cleanup {
            // Safety net: remove the image if any stage left it behind.
            sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest 2>/dev/null || true"
        }
    }
}
